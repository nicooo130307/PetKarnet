<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    android:paddingBottom="40dp"
    tools:context=".registro_mascota_vet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alta de Paciente"
            android:textColor="@color/negrito"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Creación de expediente clínico local"
            android:textColor="#666666"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Ficha Médica"
                    android:textColor="@color/negrito"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_foto_paciente"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/Azulito"
                    android:padding="20dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:scaleType="centerInside"
                    app:shapeAppearanceOverlay="@style/EstiloFotoCircular"
                    app:strokeColor="@color/AzulOscuro"
                    app:strokeWidth="3dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toca para añadir una fotografía"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:layout_marginBottom="24dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_nombre_paciente"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Nombre del Paciente"
                    app:boxStrokeColor="@color/Azulito"
                    app:hintTextColor="@color/Azulito">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nombre_paciente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Especie:"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rg_especie_paciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/rb_perro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Canino"
                        android:checked="true"
                        app:buttonTint="@color/Azulito"/>

                    <RadioButton
                        android:id="@+id/rb_gato"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Felino"
                        app:buttonTint="@color/Azulito"/>
                </RadioGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_raza_paciente"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Raza"
                    app:boxStrokeColor="@color/Azulito"
                    app:hintTextColor="@color/Azulito">

                    <AutoCompleteTextView
                        android:id="@+id/et_raza_paciente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:popupBackground="@android:color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_sexo_paciente"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Sexo"
                    app:boxStrokeColor="@color/Azulito"
                    app:hintTextColor="@color/Azulito">

                    <AutoCompleteTextView
                        android:id="@+id/et_sexo_paciente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:popupBackground="@android:color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_color_paciente"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Color / Señas particulares"
                    app:boxStrokeColor="@color/Azulito"
                    app:hintTextColor="@color/Azulito">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_color_paciente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>



                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_edad_paciente"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Edad"
                        app:boxStrokeColor="@color/Azulito"
                        app:hintTextColor="@color/Azulito">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_edad_paciente"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_peso_paciente"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Peso (Kg)"
                        app:boxStrokeColor="@color/Azulito"
                        app:hintTextColor="@color/Azulito">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_peso_paciente"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2. Datos del Propietario"
                    android:textColor="@color/negrito"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_nombre_propietario"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Nombre Completo"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="#999999"
                    app:boxStrokeColor="@color/Azulito"
                    app:hintTextColor="@color/Azulito">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nombre_propietario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_telefono_propietario"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Teléfono de Contacto"
                    app:startIconDrawable="@android:drawable/ic_menu_call"
                    app:startIconTint="#999999"
                    app:boxStrokeColor="@color/Azulito"
                    app:hintTextColor="@color/Azulito">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_telefono_propietario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_direccion_propietario"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Dirección (Opcional)"
                    app:startIconDrawable="@android:drawable/ic_dialog_map"
                    app:startIconTint="#999999"
                    app:boxStrokeColor="@color/Azulito"
                    app:hintTextColor="@color/Azulito">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_direccion_propietario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_crear_expediente"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Crear Expediente Médico"
            android:textSize="18sp"
            android:textColor="@color/negrito"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/amarillo"/>

    </LinearLayout>
</ScrollView>