<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".PerfilVeterinario">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¡Bienvenido, Doctor!"
            android:textAlignment="center"
            android:textColor="@color/negrito"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registra los datos de tu clínica o consultorio"
            android:textAlignment="center"
            android:textColor="#666666"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />



        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_foto_vet"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="8dp"
            android:background="@color/Azulito"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_camera"
            android:scaleType="centerInside"
            app:shapeAppearanceOverlay="@style/EstiloFotoCircular"
            app:strokeColor="@color/AzulOscuro"
            app:strokeWidth="3dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sube tu foto o logo de la clínica"
            android:textColor="@color/negrito"
            android:fontFamily="@font/roboto"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />





        <!-- Campo: Nombre de la Clínica -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_nombre_clinica"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Nombre de la Clínica o Consultorio"
            app:boxStrokeColor="@color/Azulito"
            app:hintTextColor="@color/negrito">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_nombre_clinica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:fontFamily="@font/roboto" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Cédula Profesional -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_cedula"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Cédula Profesional"
            app:boxStrokeColor="@color/Azulito"
            app:hintTextColor="@color/negrito">

            <!-- Le ponemos inputType="number" porque las cédulas suelen ser numéricas -->
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_cedula"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:fontFamily="@font/roboto" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Teléfono -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_telefono_clinica"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Teléfono de Contacto"
            app:boxStrokeColor="@color/Azulito"
            app:hintTextColor="@color/negrito">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_telefono_clinica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:fontFamily="@font/roboto" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Dirección -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_direccion_clinica"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Dirección Completa"
            app:boxStrokeColor="@color/Azulito"
            app:hintTextColor="@color/negrito">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_direccion_clinica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPostalAddress"
                android:fontFamily="@font/roboto" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Horario -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_horario"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="Horario (Ej. L-V 9:00 a 18:00)"
            app:boxStrokeColor="@color/Azulito"
            app:hintTextColor="@color/negrito">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_horario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:fontFamily="@font/roboto" />
        </com.google.android.material.textfield.TextInputLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:background="#F3F4F6"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️"
                android:textSize="24sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Por seguridad de la comunidad, tu Cédula Profesional será verificada por nuestro equipo. Al aprobarse, recibirás tu insignia de Veterinario Verificado."
                android:textColor="#555555"
                android:fontFamily="@font/roboto"
                android:textSize="13sp" />
        </LinearLayout>





        <!-- Botón de Guardar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardar_clinica"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Comenzar a usar PetKarnet"
            android:textSize="18sp"
            android:textColor="@color/negrito"
            app:cornerRadius="50dp"
            app:backgroundTint="@color/amarillo" />

    </LinearLayout>
</ScrollView>