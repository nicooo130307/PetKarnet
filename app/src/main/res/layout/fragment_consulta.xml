<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:clipToPadding="false"
    android:paddingBottom="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoja Clínica"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/negrito"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.- Identificación del Paciente"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/negrito"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/ll_opciones_identificacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_escanear_qr_consulta"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Escanear QR de PetKarnet"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconTint="@color/negrito"
                        android:textColor="@color/negrito"
                        app:backgroundTint="@color/amarillo"
                        app:cornerRadius="8dp"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buscar_manual_consulta"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Registro Manual (No tiene la app)"
                        app:icon="@android:drawable/ic_menu_edit"
                        app:iconTint="@color/Azulito"
                        android:textColor="@color/Azulito"
                        app:strokeColor="@color/Azulito"
                        app:cornerRadius="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_paciente_seleccionado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/Azulito"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paciente Activo:" android:textSize="12sp" android:textColor="#999999"/>
                        <TextView
                            android:id="@+id/tv_nombre_paciente_activo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Max"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/Azulito"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/ll_seccion_motivo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.- Selecciona el motivo"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/negrito"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Cuál es el motivo?"
                        android:textStyle="bold"
                        android:textColor="@color/negrito"
                        android:layout_marginBottom="8dp"/>

                    <RadioGroup
                        android:id="@+id/rg_motivo_consulta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rb_vacuna"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💉 Vacunación"
                            app:buttonTint="@color/Azulito"/>

                        <RadioButton
                            android:id="@+id/rb_desparasitacion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💊 Desparasitación"
                            app:buttonTint="@color/Azulito"/>

                        <RadioButton
                            android:id="@+id/rb_estetica"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛁 Estética y Baño"
                            app:buttonTint="@color/Azulito"/>

                        <RadioButton
                            android:id="@+id/rb_general"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🩺 Consulta Médica General"
                            app:buttonTint="@color/Azulito"/>
                    </RadioGroup>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_aceptar_motivo"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Aceptar"
                        android:textColor="@color/negrito"
                        app:backgroundTint="@color/amarillo"
                        app:cornerRadius="50dp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_seccion_detalles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.- Detalles Médicos"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/negrito"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">



                    <LinearLayout
                        android:id="@+id/ll_campos_vacunacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">


                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nombre de la Vacuna"
                            app:boxStrokeColor="@color/Azulito"
                            app:hintTextColor="@color/Azulito"
                            android:layout_marginBottom="16dp">

                            <AutoCompleteTextView
                                android:id="@+id/et_nombre_vacuna"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:popupBackground="@android:color/white"/>
                        </com.google.android.material.textfield.TextInputLayout>



                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fotografía de la Etiqueta (Lote)"
                            android:textStyle="bold"
                            android:textColor="@color/negrito"
                            android:layout_marginBottom="8dp"/>

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_foto_vacuna"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:background="@color/Azulito"
                            android:padding="20dp"
                            android:src="@drawable/agrega_foto"
                            android:scaleType="centerInside"
                            app:shapeAppearanceOverlay="@style/EstiloFotoCircular"
                            app:strokeColor="@color/AzulOscuro"
                            app:strokeWidth="3dp" />



                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:hint="Aplicación"
                                app:startIconDrawable="@android:drawable/ic_menu_today"
                                app:boxStrokeColor="@color/Azulito"
                                app:hintTextColor="@color/Azulito">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_fecha_aplicacion"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:clickable="true"
                                    android:inputType="none"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:hint="Próxima Dosis"
                                app:startIconDrawable="@android:drawable/ic_menu_month"
                                app:boxStrokeColor="@color/Azulito"
                                app:hintTextColor="@color/Azulito">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_fecha_proxima"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:clickable="true"
                                    android:inputType="none"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Comentarios / Observaciones"
                            app:boxStrokeColor="@color/Azulito"
                            app:hintTextColor="@color/Azulito"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_comentarios_vacuna"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine"
                                android:lines="3"
                                android:gravity="top"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/ll_campos_desparasitacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nombre del Desparasitante"
                            app:boxStrokeColor="@color/Azulito"
                            app:hintTextColor="@color/Azulito"
                            android:layout_marginBottom="16dp">

                            <AutoCompleteTextView
                                android:id="@+id/et_nombre_desparasitante"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:popupBackground="@android:color/white"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fotografía de la Etiqueta/Caja"
                            android:textStyle="bold"
                            android:textColor="@color/negrito"
                            android:layout_marginBottom="8dp"/>

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_foto_desparasitante"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:background="@color/Azulito"
                            android:padding="20dp"
                            android:src="@drawable/agrega_foto"
                            android:scaleType="centerInside"
                            app:shapeAppearanceOverlay="@style/EstiloFotoCircular"
                            app:strokeColor="@color/AzulOscuro"
                            app:strokeWidth="3dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:hint="Aplicación"
                                app:startIconDrawable="@android:drawable/ic_menu_today"
                                app:boxStrokeColor="@color/Azulito"
                                app:hintTextColor="@color/Azulito">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_fecha_aplicacion_desp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:clickable="true"
                                    android:inputType="none"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:hint="Próxima Dosis"
                                app:startIconDrawable="@android:drawable/ic_menu_month"
                                app:boxStrokeColor="@color/Azulito"
                                app:hintTextColor="@color/Azulito">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_fecha_proxima_desp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:clickable="true"
                                    android:inputType="none"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Comentarios / Observaciones"
                            app:boxStrokeColor="@color/Azulito"
                            app:hintTextColor="@color/Azulito"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_comentarios_desp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine"
                                android:lines="3"
                                android:gravity="top"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_campos_clinicos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Peso actual (Kg)"
                            app:boxStrokeColor="@color/Azulito"
                            app:hintTextColor="@color/Azulito"
                            android:layout_marginBottom="16dp">
                            <com.google.android.material.textfield.TextInputEditText android:inputType="numberDecimal" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        </com.google.android.material.textfield.TextInputLayout>


                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Temperatura (°C)"
                            app:boxStrokeColor="@color/Azulito"
                            app:hintTextColor="@color/Azulito"
                            android:layout_marginBottom="16dp">
                            <com.google.android.material.textfield.TextInputEditText android:inputType="numberDecimal" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Notas Médicas / Diagnóstico"
                            app:boxStrokeColor="@color/Azulito"
                            app:hintTextColor="@color/Azulito">
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine"
                                android:lines="4"
                                android:gravity="top"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_finalizar_consulta"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Finalizar y Guardar"
                android:textSize="18sp"
                android:textColor="@color/negrito"
                app:backgroundTint="@color/amarillo"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>