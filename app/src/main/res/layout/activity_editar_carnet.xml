<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"> <!-- Fondo gris clarito para que resalten las tarjetas -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- ========================================== -->
        <!-- SECCIÓN 1: CABECERA DEL PACIENTE           -->
        <!-- ========================================== -->

        <!-- Foto Circular de la Mascota -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_perfil_mascota_carnet"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="#E0E0E0"
            android:padding="4dp"
            android:src="@drawable/ic_huella"
            android:scaleType="centerInside"
            app:shapeAppearanceOverlay="@style/EstiloFotoCircular"
            app:strokeColor="@color/Azulito"
            app:strokeWidth="4dp"
            android:layout_marginTop="52dp"/>

        <!-- Nombre y Datos Rápidos -->
        <TextView
            android:id="@+id/tv_nombre_mascota_carnet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de tu Mascota"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/negrito"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tv_detalles_mascota_carnet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Raza • Edad • Peso"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="32dp"/>

        <!-- ========================================== -->
        <!-- SECCIÓN 2: TARJETA DE VACUNAS              -->
        <!-- ========================================== -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💉 Historial de Vacunación"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/negrito"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:id="@+id/ll_lista_vacunas_guardadas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Parvovirus (Aplicada: 10/Ene/25)"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:paddingBottom="8dp"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_abrir_form_vacuna"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Añadir Nueva Vacuna"
                    android:textColor="@color/Azulito"
                    app:strokeColor="@color/Azulito"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/ll_formulario_vacuna_dueno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre de la Vacuna"
                        app:boxStrokeColor="@color/Azulito"
                        android:layout_marginBottom="16dp">

                        <AutoCompleteTextView
                            android:id="@+id/et_nombre_vacuna_dueno"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:popupBackground="@android:color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fotografía de la Etiqueta / Lote"
                        android:textStyle="bold"
                        android:textColor="@color/negrito"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_foto_vacuna_dueno"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="16dp"
                        android:background="@color/Azulito"
                        android:padding="20dp"
                        android:src="@drawable/agrega_foto"
                        android:scaleType="centerInside"
                        app:shapeAppearanceOverlay="@style/EstiloFotoCircular" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:hint="Aplicación">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_fecha_app_vacuna"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:hint="Próxima">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_fecha_prox_vacuna"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>




                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Comentarios / Observaciones"
                        app:boxStrokeColor="@color/Azulito"
                        app:hintTextColor="@color/Azulito"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_comentarios_vacuna"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:lines="3"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_guardar_vacuna_individual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Guardar Vacuna"
                        app:backgroundTint="@color/amarillo"
                        android:textColor="@color/negrito"
                        app:cornerRadius="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💊 Historial de Desparasitación"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/negrito"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:id="@+id/ll_lista_desp_guardadas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• NexGard Spectra (Aplicada: 05/Mar/26)"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:paddingBottom="8dp"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_abrir_form_desp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Añadir Nuevo Producto"
                    android:textColor="@color/Azulito"
                    app:strokeColor="@color/Azulito"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/ll_formulario_desp_dueno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre del Producto"
                        app:boxStrokeColor="@color/Azulito"
                        android:layout_marginBottom="16dp">

                        <AutoCompleteTextView
                            android:id="@+id/et_nombre_desp_dueno"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:popupBackground="@android:color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fotografía de la Caja / Ampolleta"
                        android:textStyle="bold"
                        android:textColor="@color/negrito"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_foto_desp_dueno"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="16dp"
                        android:background="@color/Azulito"
                        android:padding="20dp"
                        android:src="@drawable/agrega_foto"
                        android:scaleType="centerInside"
                        app:shapeAppearanceOverlay="@style/EstiloFotoCircular" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:hint="Aplicación">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_fecha_app_desp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:hint="Próxima">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_fecha_prox_desp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>




                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Comentarios / Observaciones"
                        app:boxStrokeColor="@color/Azulito"
                        app:hintTextColor="@color/Azulito"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_comentarios_desp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:lines="3"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_guardar_desp_individual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Guardar Desparasitación"
                        app:backgroundTint="@color/amarillo"
                        android:textColor="@color/negrito"
                        app:cornerRadius="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================================== -->
        <!-- SECCIÓN 1.5: DATOS DE CONTACTO (EDICIÓN)   -->
        <!-- ========================================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Datos de Contacto"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/negrito"
                    android:layout_marginBottom="16dp"/>

                <!-- Campo para el Nombre del Dueño -->
                <EditText
                    android:id="@+id/et_nombre_dueno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre del Propietario"
                    android:inputType="textPersonName"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Campo para el Teléfono -->
                <EditText
                    android:id="@+id/et_telefono_dueno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Teléfono de Emergencia"
                    android:inputType="phone"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Campo para la Dirección -->
                <EditText
                    android:id="@+id/et_direccion_dueno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Dirección Completa"
                    android:inputType="textPostalAddress"
                    android:textSize="16sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>






        <!-- Botón de Guardar Cambios -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardar_carnet"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Actualizar Carnet"
            android:textSize="18sp"
            android:textColor="@color/negrito"
            app:cornerRadius="50dp"
            app:backgroundTint="@color/amarillo"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>